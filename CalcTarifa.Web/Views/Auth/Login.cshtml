@model CalcTarifa.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Bienvenido</h2>
            <p>Inicia sesión para ver tu historial de envíos.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
        {
            <div class="auth-alert">
                @Model.ErrorMensaje
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-field">
                <label asp-for="Email">Correo electrónico</label>
                <input asp-for="Email" class="form-input" placeholder="ejemplo@correo.com" autofocus />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Password">Contraseña</label>
                <input asp-for="Password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn-auth">Entrar</button>
        </form>

        <div class="auth-footer">
            ¿No tienes cuenta? <a asp-action="Registro">Regístrate aquí</a>
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }
    .auth-card {
        background: var(--white);
        border: 1px solid var(--n-200);
        width: 100%;
        max-width: 400px;
        padding: 2.5rem;
    }
    .auth-header h2 {
        margin: 0 0 .5rem;
        font-size: 1.5rem;
        color: var(--n-900);
    }
    .auth-header p {
        margin: 0 0 2rem;
        color: var(--n-500);
        font-size: .875rem;
    }
    .auth-alert {
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #b91c1c;
        padding: .75rem;
        font-size: .875rem;
        margin-bottom: 1.5rem;
    }
    .btn-auth {
        width: 100%;
        padding: .875rem;
        background: var(--g-600);
        color: var(--white);
        border: none;
        font-family: var(--font);
        font-weight: 700;
        cursor: pointer;
        transition: background .15s;
        margin-top: 1rem;
    }
    .btn-auth:hover {
        background: var(--g-700);
    }
    .auth-footer {
        margin-top: 2rem;
        text-align: center;
        font-size: .875rem;
        color: var(--n-500);
    }
    .auth-footer a {
        color: var(--g-600);
        font-weight: 600;
        text-decoration: none;
    }
    .auth-footer a:hover {
        text-decoration: underline;
    }
</style>
