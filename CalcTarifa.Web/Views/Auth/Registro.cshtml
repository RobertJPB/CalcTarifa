@model CalcTarifa.Web.Models.RegistroViewModel
@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Crear Cuenta</h2>
            <p>Únete para guardar tu historial de consultas de envío.</p>
        </div>

        @if (Model.Errores != null && Model.Errores.Any())
        {
            <div class="auth-alert">
                <ul style="margin:0; padding-left: 1.2rem;">
                    @foreach (var error in Model.Errores)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Registro" method="post">
            <div class="form-field">
                <label asp-for="Email">Correo electrónico</label>
                <input asp-for="Email" class="form-input" placeholder="ejemplo@correo.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="NombreCompleto">Nombre completo</label>
                <input asp-for="NombreCompleto" class="form-input" placeholder="Tu nombre" />
                <span asp-validation-for="NombreCompleto" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Password">Contraseña</label>
                <input asp-for="Password" class="form-input" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="ConfirmarPassword">Confirmar contraseña</label>
                <input asp-for="ConfirmarPassword" class="form-input" placeholder="Repite tu contraseña" />
                <span asp-validation-for="ConfirmarPassword" class="field-validation-error"></span>
            </div>



            <button type="submit" class="btn-auth">Crear cuenta</button>
        </form>

        <div class="auth-footer">
            ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a>
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }
    .auth-card {
        background: var(--white);
        border: 1px solid var(--n-200);
        width: 100%;
        max-width: 400px;
        padding: 2.5rem;
    }
    .auth-header h2 {
        margin: 0 0 .5rem;
        font-size: 1.5rem;
        color: var(--n-900);
    }
    .auth-header p {
        margin: 0 0 2rem;
        color: var(--n-500);
        font-size: .875rem;
    }
    .auth-alert {
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #b91c1c;
        padding: .75rem;
        font-size: .875rem;
        margin-bottom: 1.5rem;
    }
    .btn-auth {
        width: 100%;
        padding: .875rem;
        background: var(--g-600);
        color: var(--white);
        border: none;
        font-family: var(--font);
        font-weight: 700;
        cursor: pointer;
        transition: background .15s;
        margin-top: 1rem;
    }
    .btn-auth:hover {
        background: var(--g-700);
    }
    .auth-footer {
        margin-top: 2rem;
        text-align: center;
        font-size: .875rem;
        color: var(--n-500);
    }
    .auth-footer a {
        color: var(--g-600);
        font-weight: 600;
        text-decoration: none;
    }
    .auth-footer a:hover {
        text-decoration: underline;
    }
</style>
